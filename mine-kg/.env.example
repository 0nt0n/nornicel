# === Yandex AI Studio ===
# API-ключ сервисного аккаунта с ролью ai.languageModels.user (создаётся в AI Studio)
YANDEX_API_KEY=
# ID каталога (folder) в Yandex Cloud
YANDEX_FOLDER_ID=
# Эндпоинт structured output. Альтернатива: https://llm.api.cloud.yandex.net/v1
YANDEX_BASE_URL=https://ai.api.cloud.yandex.net/v1

# Модели (без gpt://-префикса, он добавляется в коде)
LLM_MODEL_MAIN=yandexgpt          # Pro — извлечение и синтез
LLM_MODEL_FAST=yandexgpt-lite     # Lite — роутинг запросов
# Тяжёлые модели, доступные в Studio: qwen3-235b-a22b-fp8, deepseek-...
LLM_MODEL_HEAVY=yandexgpt

# === Эмбеддинги ===
# yandex (в контуре) или e5 (локальный, офлайн; тогда раскомментируй sentence-transformers в requirements)
EMBED_BACKEND=yandex

# === Neo4j (должно совпадать с docker-compose.yml) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# === Пайплайн ===
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
